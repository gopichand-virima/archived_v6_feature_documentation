{
      "name": "Production-Virima Documentation Website",
      "version": "0.1.0",
      "private": true,
      "packageManager": "pnpm@9.15.0",
      "engines": {
            "node": ">=20.0.0",
            "pnpm": ">=9.0.0"
      },
      "dependencies": {
            "@radix-ui/react-accordion": "^1.2.3",
            "@radix-ui/react-alert-dialog": "^1.1.6",
            "@radix-ui/react-aspect-ratio": "^1.1.2",
            "@radix-ui/react-avatar": "^1.1.3",
            "@radix-ui/react-checkbox": "^1.1.4",
            "@radix-ui/react-collapsible": "^1.1.3",
            "@radix-ui/react-context-menu": "^2.2.6",
            "@radix-ui/react-dialog": "^1.1.6",
            "@radix-ui/react-dropdown-menu": "^2.1.6",
            "@radix-ui/react-hover-card": "^1.1.6",
            "@radix-ui/react-label": "^2.1.2",
            "@radix-ui/react-menubar": "^1.1.6",
            "@radix-ui/react-navigation-menu": "^1.2.5",
            "@radix-ui/react-popover": "^1.1.6",
            "@radix-ui/react-progress": "^1.1.2",
            "@radix-ui/react-radio-group": "^1.2.3",
            "@radix-ui/react-scroll-area": "^1.2.3",
            "@radix-ui/react-select": "^2.1.6",
            "@radix-ui/react-separator": "^1.1.2",
            "@radix-ui/react-slider": "^1.2.3",
            "@radix-ui/react-slot": "^1.1.2",
            "@radix-ui/react-switch": "^1.1.3",
            "@radix-ui/react-tabs": "^1.1.3",
            "@radix-ui/react-toggle": "^1.1.2",
            "@radix-ui/react-toggle-group": "^1.1.2",
            "@radix-ui/react-tooltip": "^1.1.8",
            "@vitejs/plugin-react": "*",
            "class-variance-authority": "^0.7.1",
            "clsx": "*",
            "cmdk": "^1.1.1",
            "emailjs-com": "^3.2.0",
            "embla-carousel-react": "^8.6.0",
            "input-otp": "^1.4.2",
            "lucide-react": "^0.487.0",
            "motion": "*",
            "next-themes": "^0.4.6",
            "re-resizable": "*",
            "react": "^18.3.1",
            "react-day-picker": "^8.10.1",
            "react-dom": "^18.3.1",
            "react-hook-form": "^7.55.0",
            "react-markdown": "*",
            "react-resizable-panels": "^2.1.7",
            "react-syntax-highlighter": "*",
            "recharts": "^2.15.2",
            "rehype-raw": "*",
            "rehype-sanitize": "^6.0.0",
            "remark-gfm": "*",
            "sonner": "^2.0.3",
            "tailwind-merge": "*",
            "vaul": "^1.1.2"
      },
      "devDependencies": {
            "@types/node": "^20.10.0",
            "@types/react": "^18.3.11",
            "@types/react-dom": "^18.3.1",
            "@vitejs/plugin-react-swc": "^3.10.2",
            "autoprefixer": "^10.4.22",
            "postcss": "^8.5.6",
            "tailwindcss": "^4.1.17",
            "tsx": "^4.19.2",
            "typescript": "^5.5.3",
            "vite": "6.3.5"
      },
      "scripts": {
            "dev": "vite",
            "build": "vite build",
            "preview": "vite preview",
            "sync-toc": "tsx --tsconfig scripts/tsconfig.json scripts/sync-toc-from-index.ts",
            "watch-toc": "tsx --tsconfig scripts/tsconfig.json scripts/watch-toc.ts",
            "build-doc-graph": "tsx --tsconfig scripts/tsconfig.json scripts/build-doc-graph.ts",
            "build-search-index": "tsx --tsconfig scripts/tsconfig.json scripts/build-search-index.ts",
            "build-sitemap": "tsx --tsconfig scripts/tsconfig.json scripts/build-sitemap.ts",
            "prebuild": "pnpm run sync-toc && pnpm run build-doc-graph && pnpm run build-search-index && pnpm run build-sitemap",
            "typecheck": "tsc -p src/tsconfig.json --noEmit",
            "check:env": "tsx scripts/checks/check-env.ts",
            "check:setup": "tsx scripts/checks/verify-setup.ts",
            "check:security": "tsx scripts/checks/verify-security.ts",
            "check:paths": "tsx scripts/checks/verify-paths.ts",
            "check:toc": "tsx --tsconfig scripts/tsconfig.json scripts/checks/verify-toc-structure.ts",
            "check:retrieval": "tsx --tsconfig scripts/tsconfig.json scripts/checks/check-retrieval-integrity.ts",
            "validate": "pnpm run typecheck && pnpm run check:security && pnpm run check:setup && pnpm run check:paths && pnpm run check:retrieval",
            "docs:validate": "tsx scripts/evals/run-evals.ts --suite=docs",
            "docs:structure": "tsx scripts/evals/run-evals.ts --suite=structure",
            "docs:links": "tsx scripts/evals/run-evals.ts --suite=links",
            "eval": "tsx scripts/evals/run-evals.ts",
            "eval:search": "tsx --tsconfig scripts/tsconfig.json scripts/evals/eval-search-quality.ts",
            "test": "vitest run scripts/__tests__",
            "memory:check": "tsx --tsconfig scripts/tsconfig.json scripts/memory/check-memory-drift.ts",
            "memory:update": "tsx --tsconfig scripts/tsconfig.json scripts/memory/update-memory.ts"
      },
      "pnpm": {
            "overrides": {
                  "@types/react": "18.3.11",
                  "@types/react-dom": "18.3.1",
                  "re-resizable>@types/react": "18.3.11"
            }
      }
}
